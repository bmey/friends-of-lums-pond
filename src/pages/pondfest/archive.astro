---
import Layout from "../../layouts/PondFestLayout.astro";
import { PONDFEST_2024 } from "../../data/pondfest/archive/2024";
import { PONDFEST_2025 } from "../../data/pondfest/archive/2025";
import type { ArchiveYear } from "../../data/pondfest/types";

// Add future years here, newest first
const years: ArchiveYear[] = [PONDFEST_2025, PONDFEST_2024];

function formatCurrency(n: number) {
  return "$" + n.toLocaleString("en-US");
}
---

<Layout
  title="Pond Fest Archive | Friends of Lums Pond"
  description="A history of every Pond Fest — the annual signature fundraiser of Friends of Lums Pond State Park."
>
  <!-- ══ HEADER ═════════════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--dark archive-header">
    <div class="pf-section-inner pf-section-inner--narrow" style="text-align:center">
      <span class="pf-eyebrow">Every October Since 2024</span>
      <h1 class="archive-title">Pond Fest Archive</h1>
      <p>
        Every second Saturday of October, Pond Fest brings the community
        together to celebrate and support Lums Pond State Park. Here is the
        story so far.
      </p>
      <a href="/pondfest" class="pf-btn pf-btn--outline-light">
        <i class="fa-solid fa-arrow-left"></i> Back to Pond Fest
      </a>
    </div>
  </section>

  <!-- ══ TOTALS BANNER ════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--purple">
    <div class="pf-section-inner totals-row">
      <div class="total-stat">
        <span class="total-num">{years.length}</span>
        <span class="total-label">Events</span>
      </div>
      <div class="total-divider"></div>
      <div class="total-stat">
        <span class="total-num">
          {
            formatCurrency(
              years.reduce((sum, y) => sum + (y.grossRevenue ?? 0), 0)
            )
          }
        </span>
        <span class="total-label">Raised for the Park</span>
      </div>
      <div class="total-divider"></div>
      <div class="total-stat">
        <span class="total-num">
          {
            years
              .reduce((sum, y) => sum + (y.attendees ?? 0), 0)
              .toLocaleString()
          }+
        </span>
        <span class="total-label">Attendees</span>
      </div>
    </div>
  </section>

  <!-- ══ YEAR CARDS ════════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--dark">
    <div class="pf-section-inner">
      {
        years.map((y) => (
          <article class="year-card">
            {/* ── Photo header ── */}
            <div class="year-card-photo">
              {y.featuredPhotoUrl ? (
                <img src={y.featuredPhotoUrl} alt={`Pond Fest ${y.year}`} />
              ) : (
                <div class="year-photo-placeholder">
                  <i class="fa-regular fa-image" />
                </div>
              )}
              <div class="year-photo-overlay">
                <span class="year-badge">{y.year}</span>
              </div>
            </div>

            {/* ── Stats bar ── */}
            <div class="year-stats-bar">
              {y.dateDisplay && (
                <span class="stat-item">
                  <i class="fa-solid fa-calendar-days" /> {y.dateDisplay}
                </span>
              )}
              {y.attendees && (
                <span class="stat-item stat-item--teal">
                  <i class="fa-solid fa-people-group" />{" "}
                  {y.attendees.toLocaleString()}+ attendees
                </span>
              )}
              {y.grossRevenue && (
                <span class="stat-item stat-item--teal">
                  <i class="fa-solid fa-circle-dollar-to-slot" />{" "}
                  {formatCurrency(y.grossRevenue)} raised
                </span>
              )}
              {y.fundraisingGoal && (
                <span class="stat-item stat-item--subtle">
                  <i class="fa-solid fa-bullseye" /> Goal:{" "}
                  {formatCurrency(y.fundraisingGoal)}
                </span>
              )}
            </div>

            {/* ── Body: highlights + goals ── */}
            <div class="year-card-body">
              <div class="year-col">
                <h3 class="year-col-label">Highlights</h3>
                <ul class="highlights-list">
                  {y.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              </div>

              <div class="year-col">
                <h3 class="year-col-label">Fundraising Goals</h3>
                {y.fundingGoals.map((goal) => (
                  <div class="archive-goal">
                    <strong>{goal.name}</strong>
                    <p>{goal.description}</p>
                  </div>
                ))}

                {(y.detailPageUrl || y.photoGalleryUrl) && (
                  <div class="year-links">
                    {y.detailPageUrl && (
                      <a href={y.detailPageUrl} class="pf-btn pf-btn--outline">
                        <i class="fa-solid fa-file-lines" /> Full Event Page
                      </a>
                    )}
                    {y.photoGalleryUrl && (
                      <a
                        href={y.photoGalleryUrl}
                        class="pf-btn pf-btn--outline"
                        target="_blank"
                        rel="noopener"
                      >
                        <i class="fa-solid fa-images" /> Photos
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ══ FOOTER CTA ════════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--purple">
    <div class="pf-section-inner pf-section-inner--narrow" style="text-align:center">
      <h2>Be Part of Pond Fest History</h2>
      <p>
        Pond Fest is held every second Saturday of October at Lums Pond State
        Park. Join us as a volunteer, vendor, sponsor, or guest.
      </p>
      <a href="/pondfest" class="pf-btn pf-btn--primary">
        See This Year's Event
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ── Page header ── */
  .archive-title {
    font-family: var(--font-header);
    font-size: clamp(2.2rem, 6vw, 4rem);
    color: var(--pf-teal-light);
    margin-bottom: 0.75rem;
    letter-spacing: 0.03em;
    line-height: 1.05;
  }
  .archive-header p {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1.5rem;
  }

  /* ── Totals banner ── */
  .totals-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 4vw, 3rem);
    flex-wrap: wrap;
    text-align: center;
  }
  .total-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .total-num {
    font-family: var(--font-header);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    color: var(--pf-teal-light);
    line-height: 1;
    padding-bottom: 0.15em;
    border-bottom: 3px solid rgba(77, 217, 203, 0.4);
  }
  .total-label {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0.5rem;
  }
  .total-divider {
    width: 1px;
    height: clamp(2.5rem, 5vw, 4rem);
    background: rgba(255, 255, 255, 0.2);
  }
  @media (max-width: 420px) {
    .total-divider { display: none; }
  }

  /* ── Year card ── */
  .year-card {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    border-radius: 16px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
  }

  /* ── Card photo header ── */
  .year-card-photo {
    position: relative;
    height: clamp(200px, 28vw, 420px);
    overflow: hidden;
  }
  .year-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .year-photo-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      var(--pf-purple-dark) 0%,
      var(--pf-purple) 55%,
      var(--pf-teal) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.15);
    font-size: clamp(3rem, 6vw, 5rem);
  }
  .year-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(11, 9, 23, 0.75) 0%,
      transparent 60%
    );
    display: flex;
    align-items: flex-end;
    padding: clamp(1rem, 3vw, 2rem) clamp(1.25rem, 3vw, 2.5rem);
  }
  .year-badge {
    font-family: var(--font-header);
    font-size: clamp(3rem, 8vw, 6rem);
    color: #fff;
    line-height: 1;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }

  /* ── Stats bar ── */
  .year-stats-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    padding: 1rem clamp(1.25rem, 3vw, 2.5rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(0, 0, 0, 0.2);
  }
  .stat-item {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
  }
  .stat-item i {
    opacity: 0.7;
  }
  .stat-item--teal {
    color: var(--pf-teal-light);
    font-weight: 600;
  }
  .stat-item--subtle {
    color: rgba(255, 255, 255, 0.45);
  }

  /* ── Card body ── */
  .year-card-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 3vw, 2.5rem);
  }
  @media (min-width: 640px) {
    .year-card-body {
      grid-template-columns: 3fr 2fr;
    }
  }

  .year-col-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--pf-teal);
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(42, 196, 179, 0.25);
  }

  .highlights-list {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.65;
  }
  .highlights-list li {
    margin-bottom: 0.35rem;
    padding-left: 1.1rem;
    position: relative;
  }
  .highlights-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.58em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--pf-teal);
  }

  .archive-goal {
    margin-bottom: 1rem;
    padding-left: 0.85rem;
    border-left: 3px solid var(--pf-teal);
  }
  .archive-goal strong {
    display: block;
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 0.2rem;
  }
  .archive-goal p {
    font-size: 0.87rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    line-height: 1.45;
  }

  .year-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }
</style>
