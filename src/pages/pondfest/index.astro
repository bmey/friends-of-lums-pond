---
import Layout from "../../layouts/PondFestLayout.astro";
import PondFestCountdown from "../../components/pondfest/PondFestCountdown.astro";
import {
  CURRENT_YEAR,
  EVENT_DATE,
  EVENT_DATE_DISPLAY,
  EVENT_TIME,
  EVENT_LOCATION,
  EVENT_TAGLINE,
  FUNDRAISING_GOAL,
  HERO_IMAGE_URL,
  TICKETS_URL,
  VOLUNTEER_URL,
  SPONSOR_URL,
  VENDOR_URL,
  PERFORMER_URL,
  PONDFEST_EMAIL,
  LINEUP,
  SPONSORS,
  FUNDING_GOALS,
  FAQ,
  DAY_OF_ALERT,
  SHUTTLE_INFO,
  PARKING_NOTES,
  RAFFLE_LINK,
  AUCTION_LINK,
  FEEDBACK_LINK,
  DONATION_EMBED_URL,
  EVENT_MAP_IMAGE_URL,
  PARKING_MAP_IMAGE_URL,
  VENDOR_MAP_IMAGE_URL,
  PHOTO_BAND_1_URL,
  GALLERY_PHOTOS,
  HISTORY_BG_PHOTO,
} from "../../data/pondfest/config";

const hasMaps = EVENT_MAP_IMAGE_URL || PARKING_MAP_IMAGE_URL || VENDOR_MAP_IMAGE_URL;

const sponsorsByTier = {
  platinum: SPONSORS.filter((s) => s.tier === "platinum"),
  gold: SPONSORS.filter((s) => s.tier === "gold"),
  silver: SPONSORS.filter((s) => s.tier === "silver"),
  bronze: SPONSORS.filter((s) => s.tier === "bronze"),
  family: SPONSORS.filter((s) => s.tier === "family"),
};

const hasSponsors = SPONSORS.length > 0;
const hasLineup = LINEUP.length > 0;

const ctaLinks = [
  { label: "Get Tickets",  url: TICKETS_URL,   style: "pf-btn--primary",       icon: "fa-ticket" },
  { label: "Volunteer",    url: VOLUNTEER_URL,  style: "pf-btn--outline-light",  icon: "fa-hand-holding-heart" },
  { label: "Sponsor",      url: SPONSOR_URL,    style: "pf-btn--outline-light",  icon: "fa-star" },
  { label: "Vend",         url: VENDOR_URL,     style: "pf-btn--outline-light",  icon: "fa-store" },
  { label: "Perform",      url: PERFORMER_URL,  style: "pf-btn--outline-light",  icon: "fa-music" },
];

// Real photos for each feature — add URLs from your Lightroom album
const features = [
  {
    icon: "fa-music",
    title: "Live Music",
    desc: "Multiple stages featuring local and regional artists throughout the day.",
    imageUrl: "", // e.g. "/pondfest/photos/live-music.jpg"
  },
  {
    icon: "fa-beer-mug-empty",
    title: "Beer Garden",
    desc: "Craft brews from Delaware's best local breweries (21+).",
    imageUrl: "", // e.g. "/pondfest/photos/beer-garden.jpg"
  },
  {
    icon: "fa-utensils",
    title: "Food Trucks",
    desc: "A variety of local food trucks for every appetite.",
    imageUrl: "", // e.g. "/pondfest/photos/food-trucks.jpg"
  },
  {
    icon: "fa-child",
    title: "Kids Zone",
    desc: "Games, crafts, face painting, and activities for all ages.",
    imageUrl: "", // e.g. "/pondfest/photos/kids-zone.jpg"
  },
  {
    icon: "fa-store",
    title: "Craft Vendors",
    desc: "40+ local artisans, crafters, and community nonprofits.",
    imageUrl: "", // e.g. "/pondfest/photos/vendors.jpg"
  },
  {
    icon: "fa-ticket",
    title: "Raffles & Auction",
    desc: "Win exciting prizes donated by local businesses and supporters.",
    imageUrl: "", // e.g. "/pondfest/photos/raffle.jpg"
  },
];

const involvedPaths = [
  {
    icon: "fa-hand-holding-heart",
    title: "Volunteer",
    desc: "Help make Pond Fest happen. We need hands for setup, kids zone, info tables, and more.",
    url: VOLUNTEER_URL,
    cta: "Sign Up to Volunteer",
  },
  {
    icon: "fa-guitar",
    title: "Perform",
    desc: "Are you a local musician or performer? We want to hear from you.",
    url: PERFORMER_URL,
    cta: "Apply to Perform",
  },
  {
    icon: "fa-store",
    title: "Vend",
    desc: "Bring your business or craft to Pond Fest and connect with the community.",
    url: VENDOR_URL,
    cta: "Apply to Vend",
  },
  {
    icon: "fa-star",
    title: "Sponsor",
    desc: "Support the park and get visibility with hundreds of community members.",
    url: SPONSOR_URL,
    cta: "Become a Sponsor",
  },
];

const tierLabels: Record<string, string> = {
  platinum: "Platinum Sponsors",
  gold: "Gold Sponsors",
  silver: "Silver Sponsors",
  bronze: "Bronze Sponsors",
  family: "Family Sponsors",
};
---

<Layout
  title={`Pond Fest ${CURRENT_YEAR} | Friends of Lums Pond`}
  description={`Pond Fest ${CURRENT_YEAR} — ${EVENT_DATE_DISPLAY}. ${EVENT_TAGLINE}`}
>
  <!-- ══ ALERT BANNER ════════════════════════════════════════════════ -->
  {DAY_OF_ALERT && (
    <div class="pf-alert-banner" role="alert">
      <i class="fa-solid fa-circle-info" />
      {DAY_OF_ALERT}
    </div>
  )}

  <!-- ══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="pf-hero" style={`background-image: url('${HERO_IMAGE_URL}')`}>
    <div class="pf-hero-overlay">
      <div class="pf-hero-content">
        <div class="pf-hero-eyebrow">Friends of Lums Pond presents</div>
        <h1 class="pf-hero-title">
          Pond Fest <span class="pf-hero-year">{CURRENT_YEAR}</span>
        </h1>
        <p class="pf-hero-meta">
          <i class="fa-solid fa-calendar-days"></i>
          {EVENT_DATE_DISPLAY}
          &nbsp;&middot;&nbsp;
          <i class="fa-solid fa-clock"></i>
          {EVENT_TIME}
          <br />
          <i class="fa-solid fa-location-dot"></i>
          {EVENT_LOCATION}
        </p>
        <p class="pf-hero-tagline">{EVENT_TAGLINE}</p>
        <PondFestCountdown startDate={EVENT_DATE} year={CURRENT_YEAR} />
        <div class="pf-hero-ctas">
          {ctaLinks.map((cta) =>
            cta.url ? (
              <a href={cta.url} class={`pf-btn ${cta.style}`} target="_blank" rel="noopener">
                <i class={`fa-solid ${cta.icon}`} />
                {cta.label}
              </a>
            ) : (
              <span class="pf-btn pf-btn--disabled" title="Link coming soon">
                <i class={`fa-solid ${cta.icon}`} />
                {cta.label}
              </span>
            )
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ DAY-OF PANEL ═══════════════════════════════════════════════ -->
  <div
    id="pf-day-of-panel"
    data-event-date={EVENT_DATE}
    style="display:none"
    class="pf-day-of-panel"
  >
    <!-- Quick navigation -->
    <section class="pf-section pf-section--purple">
      <div class="pf-section-inner pf-section-inner--mid">
        <h2>Day-of Quick Links</h2>
        <div class="pf-dayof-quicknav">
          {hasMaps && <a href="#pf-maps" class="pf-quicknav-btn"><i class="fa-solid fa-map"></i> Maps</a>}
          {RAFFLE_LINK && <a href={RAFFLE_LINK} target="_blank" rel="noopener" class="pf-quicknav-btn"><i class="fa-solid fa-ticket"></i> Raffles</a>}
          {AUCTION_LINK && <a href={AUCTION_LINK} target="_blank" rel="noopener" class="pf-quicknav-btn"><i class="fa-solid fa-gavel"></i> Auction</a>}
          {DONATION_EMBED_URL && <a href="#pf-donate" class="pf-quicknav-btn"><i class="fa-solid fa-circle-dollar-to-slot"></i> Donate</a>}
          {FEEDBACK_LINK && <a href={FEEDBACK_LINK} target="_blank" rel="noopener" class="pf-quicknav-btn"><i class="fa-solid fa-comment-dots"></i> Feedback</a>}
        </div>
      </div>
    </section>

    {hasMaps && (
      <section class="pf-section pf-section--dark-alt" id="pf-maps">
        <div class="pf-section-inner pf-section-inner--mid">
          <h2>Event Maps</h2>
          <div class="pf-maps-grid">
            {EVENT_MAP_IMAGE_URL && (
              <div class="pf-map-item">
                <h3>Event Map</h3>
                <a href={EVENT_MAP_IMAGE_URL} target="_blank" rel="noopener">
                  <img src={EVENT_MAP_IMAGE_URL} alt="Pond Fest event map" class="pf-map-img" loading="lazy" />
                  <span class="pf-map-tap-hint"><i class="fa-solid fa-magnifying-glass-plus"></i> Tap to enlarge</span>
                </a>
              </div>
            )}
            {PARKING_MAP_IMAGE_URL && (
              <div class="pf-map-item">
                <h3>Parking Map</h3>
                <a href={PARKING_MAP_IMAGE_URL} target="_blank" rel="noopener">
                  <img src={PARKING_MAP_IMAGE_URL} alt="Pond Fest parking map" class="pf-map-img" loading="lazy" />
                  <span class="pf-map-tap-hint"><i class="fa-solid fa-magnifying-glass-plus"></i> Tap to enlarge</span>
                </a>
              </div>
            )}
            {VENDOR_MAP_IMAGE_URL && (
              <div class="pf-map-item">
                <h3>Vendor Map</h3>
                <a href={VENDOR_MAP_IMAGE_URL} target="_blank" rel="noopener">
                  <img src={VENDOR_MAP_IMAGE_URL} alt="Pond Fest vendor map" class="pf-map-img" loading="lazy" />
                  <span class="pf-map-tap-hint"><i class="fa-solid fa-magnifying-glass-plus"></i> Tap to enlarge</span>
                </a>
              </div>
            )}
          </div>
          {PARKING_NOTES && (
            <div class="pf-info-note">
              <i class="fa-solid fa-circle-parking"></i>
              <p>{PARKING_NOTES}</p>
            </div>
          )}
          {SHUTTLE_INFO && (
            <div class="pf-info-note">
              <i class="fa-solid fa-bus"></i>
              <p>{SHUTTLE_INFO}</p>
            </div>
          )}
        </div>
      </section>
    )}

    {(RAFFLE_LINK || AUCTION_LINK) && (
      <section class="pf-section pf-section--dark">
        <div class="pf-section-inner pf-section-inner--mid">
          <h2>Raffles &amp; Auction</h2>
          <div class="pf-dayof-link-cards">
            {RAFFLE_LINK && (
              <a href={RAFFLE_LINK} target="_blank" rel="noopener" class="pf-dayof-link-card">
                <i class="fa-solid fa-ticket pf-dayof-link-icon"></i>
                <div>
                  <strong>Raffle Info &amp; Results</strong>
                  <p>View raffle items and winner announcements</p>
                </div>
                <i class="fa-solid fa-arrow-right pf-dayof-link-arrow"></i>
              </a>
            )}
            {AUCTION_LINK && (
              <a href={AUCTION_LINK} target="_blank" rel="noopener" class="pf-dayof-link-card">
                <i class="fa-solid fa-gavel pf-dayof-link-icon"></i>
                <div>
                  <strong>Silent Auction</strong>
                  <p>View auction items and place or check bids</p>
                </div>
                <i class="fa-solid fa-arrow-right pf-dayof-link-arrow"></i>
              </a>
            )}
          </div>
        </div>
      </section>
    )}

    {DONATION_EMBED_URL && (
      <section class="pf-section pf-section--dark-alt" id="pf-donate">
        <div class="pf-section-inner--narrow pf-donate-section">
          <h2>Donate Today</h2>
          <p>Every dollar raised goes directly to Lums Pond State Park programs and facilities.</p>
          <script src="https://donorbox.org/widget.js" paypalExpress="false" is:inline></script>
          <iframe
            src={DONATION_EMBED_URL}
            name="donorbox"
            allowpaymentrequest="allowpaymentrequest"
            seamless="seamless"
            frameborder="0"
            scrolling="no"
            height="900px"
            width="100%"
            style="max-width: 500px; min-width: 250px; max-height: none !important; display: block; margin: 0 auto;"
            allow="payment"
          />
        </div>
      </section>
    )}

    {FEEDBACK_LINK && (
      <section class="pf-section pf-section--purple">
        <div class="pf-section-inner--narrow pf-feedback-section">
          <h2>Share Your Feedback</h2>
          <p>
            Thank you for spending the day with us at Pond Fest! Your feedback helps
            us make next year even better. It only takes two minutes.
          </p>
          <a href={FEEDBACK_LINK} target="_blank" rel="noopener" class="pf-btn pf-btn--outline-light">
            <i class="fa-solid fa-comment-dots"></i> Go to Survey
          </a>
        </div>
      </section>
    )}
  </div>
  <!-- ══ END DAY-OF PANEL ═══════════════════════════════════════════ -->

  <!-- ══ FUNDRAISING GOALS — split image+text on purple ════════════ -->
  {FUNDING_GOALS.length > 0 && (
    <section class="pf-section pf-section--purple pf-goals-section">
      <div class="pf-section-inner pf-section-inner--narrow pf-goals-intro">
        <span class="pf-eyebrow">Fundraising for {CURRENT_YEAR}</span>
        <h2>Raising {FUNDRAISING_GOAL} for the Park</h2>
        <p>Every dollar raised at Pond Fest goes directly to Lums Pond State Park programs and facilities.</p>
      </div>

      {FUNDING_GOALS.map((goal, i) => (
        <div class={`pf-split ${i % 2 !== 0 ? "pf-split--reverse" : ""} pf-goals-split`}>
          <div class="pf-split-media">
            {goal.imageUrl
              ? <img src={goal.imageUrl} alt={goal.name} loading="lazy" />
              : <div class="pf-img-placeholder"><i class="fa-solid fa-camera" /></div>
            }
          </div>
          <div class="pf-split-text">
            <h3>{goal.name}</h3>
            <p>{goal.description}</p>
            {goal.donorboxUrl
              ? <a href={goal.donorboxUrl} class="pf-btn pf-btn--primary" target="_blank" rel="noopener">Donate to this goal</a>
              : <span class="pf-goals-donate-soon">Donation link coming soon</span>
            }
          </div>
        </div>
      ))}
    </section>
  )}

  <!-- ══ WHAT TO EXPECT — photo tiles on light bg ══════════════════ -->
  <section class="pf-section pf-section--light">
    <div class="pf-section-inner">
      <div class="pf-expect-header">
        <span class="pf-eyebrow">The Experience</span>
        <h2>What to Expect</h2>
      </div>
      <div class="pf-features-grid">
        {features.map((f) => (
          <div class="pf-feature-tile">
            <div class="pf-feature-media">
              {f.imageUrl
                ? <img src={f.imageUrl} alt={f.title} loading="lazy" />
                : (
                  <div class="pf-feature-icon-bg">
                    <i class={`fa-solid ${f.icon}`} />
                  </div>
                )
              }
            </div>
            <div class="pf-feature-body">
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ MUSIC LINEUP ═══════════════════════════════════════════════ -->
  <section class="pf-section pf-section--dark">
    <div class="pf-section-inner pf-section-inner--mid">
      {hasLineup ? (
        <>
          <div class="pf-lineup-header">
            <span class="pf-eyebrow">Live Music</span>
            <h2>Music Lineup</h2>
          </div>
          <div class="pf-lineup-grid">
            {LINEUP.map((performer) => (
              <div class="pf-performer-row">
                <div class="pf-performer-name">{performer.name}</div>
                {performer.stage && <span class="pf-performer-stage">{performer.stage}</span>}
                {performer.time && <span class="pf-performer-time">{performer.time}</span>}
              </div>
            ))}
          </div>
        </>
      ) : (
        <div class="pf-coming-soon">
          <span class="pf-eyebrow">Live Music</span>
          <h2 class="pf-coming-soon-headline">Lineup Coming Soon</h2>
          <div class="pf-coming-soon-line" />
          <p>
            Artist announcements drop as we get closer to October — follow us on{" "}
            <a href="https://www.facebook.com/FriendsofLumsPond" target="_blank" rel="noopener">
              Facebook
            </a>{" "}
            so you don't miss it.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ══ PHOTO BAND ═════════════════════════════════════════════════ -->
  <div
    class="pf-photo-band"
    style={PHOTO_BAND_1_URL ? `background-image: url('${PHOTO_BAND_1_URL}')` : undefined}
    role="img"
    aria-label="Pond Fest event photo"
  >
    {!PHOTO_BAND_1_URL && (
      <div class="pf-photo-band-placeholder">
        <i class="fa-solid fa-camera" />
      </div>
    )}
  </div>

  <!-- ══ GET INVOLVED ═══════════════════════════════════════════════ -->
  <section class="pf-section pf-section--dark">
    <div class="pf-section-inner pf-section-inner--mid">
      <div class="pf-involved-header">
        <span class="pf-eyebrow">Be Part of It</span>
        <h2>Get Involved</h2>
      </div>
      <div class="pf-involved-grid">
        {involvedPaths.map((path) => (
          <div class="pf-involved-card">
            <i class={`fa-solid ${path.icon} pf-involved-icon`} />
            <h3>{path.title}</h3>
            <p>{path.desc}</p>
            {path.url ? (
              <a href={path.url} class="pf-btn pf-btn--outline-light" target="_blank" rel="noopener">
                {path.cta}
              </a>
            ) : (
              <span class="pf-btn pf-btn--disabled">{path.cta} — Coming Soon</span>
            )}
          </div>
        ))}
      </div>
      <div class="pf-involved-more">
        <a href="/pondfest/involved" class="pf-btn pf-btn--primary">
          Learn More About Getting Involved
        </a>
      </div>
    </div>
  </section>

  <!-- ══ SPONSORS ═══════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--light-alt">
    <div class="pf-section-inner pf-section-inner--mid pf-sponsors-inner">
      <span class="pf-eyebrow">Thank You</span>
      <h2>Sponsors</h2>
      {hasSponsors ? (
        <div class="pf-sponsor-tiers">
          {(["platinum", "gold", "silver", "bronze", "family"] as const).map(
            (tier) =>
              sponsorsByTier[tier].length > 0 && (
                <div class="pf-sponsor-tier">
                  <h3 class="pf-sponsor-tier-label">{tierLabels[tier]}</h3>
                  <div class="pf-sponsor-list">
                    {sponsorsByTier[tier].map((s) =>
                      s.url ? (
                        <a href={s.url} target="_blank" rel="noopener" class="pf-sponsor-name">
                          {s.name}
                        </a>
                      ) : (
                        <span class="pf-sponsor-name">{s.name}</span>
                      )
                    )}
                  </div>
                </div>
              )
          )}
        </div>
      ) : (
        <div class="pf-sponsor-empty">
          <p>
            Interested in sponsoring Pond Fest {CURRENT_YEAR}?{" "}
            {SPONSOR_URL ? (
              <a href={SPONSOR_URL} target="_blank" rel="noopener">Fill out our sponsor interest form</a>
            ) : (
              <>Reach out to <a href={`mailto:${PONDFEST_EMAIL}`}>{PONDFEST_EMAIL}</a></>
            )}
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ══ FAQ — 2-column on desktop ═════════════════════════════════ -->
  <section class="pf-section pf-section--dark-alt">
    <div class="pf-section-inner pf-faq-layout">
      <div class="pf-faq-intro">
        <span class="pf-eyebrow">Questions</span>
        <h2>Frequently Asked Questions</h2>
        <p>Everything you need to know about Pond Fest. Can't find your answer? Email <a href={`mailto:${PONDFEST_EMAIL}`}>{PONDFEST_EMAIL}</a></p>
      </div>
      <div class="pf-faq">
        {FAQ.map((item, i) => (
          <div class="pf-faq-item" id={`faq-${i}`}>
            <button
              class="pf-faq-button"
              type="button"
              aria-expanded="false"
              aria-controls={`faq-content-${i}`}
              id={`faq-btn-${i}`}
            >
              <span>{item.question}</span>
              <svg
                class="pf-faq-chevron"
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
              >
                <path
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="m6 9l6 6l6-6"
                />
              </svg>
            </button>
            <div
              id={`faq-content-${i}`}
              aria-labelledby={`faq-btn-${i}`}
              class="pf-faq-content"
            >
              <p>{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ GALLERY ════════════════════════════════════════════════════ -->
  <div class="pf-gallery-grid" aria-label="Pond Fest photo gallery">
    {GALLERY_PHOTOS.length > 0
      ? GALLERY_PHOTOS.slice(0, 4).map((url) => (
          <div class="pf-gallery-item">
            <img src={url} alt="Pond Fest event" loading="lazy" />
          </div>
        ))
      : [0, 1, 2, 3].map((i) => (
          <div class="pf-gallery-item">
            <div class="pf-img-placeholder">
              <i class="fa-solid fa-camera" />
            </div>
          </div>
        ))
    }
  </div>

  <!-- ══ HISTORY TEASER ═════════════════════════════════════════════ -->
  <section
    class="pf-section pf-section--dark pf-history-section"
    style={HISTORY_BG_PHOTO ? `background-image: url('${HISTORY_BG_PHOTO}')` : undefined}
  >
    <div class="pf-section-inner pf-section-inner--narrow pf-history-inner">
      <span class="pf-eyebrow">Since 2024</span>
      <h2>Our History</h2>
      <div class="pf-history-stats">
        <div class="pf-history-stat">
          <span class="pf-history-stat-num">2</span>
          <span class="pf-history-stat-label">Years</span>
        </div>
        <span class="pf-history-stat-dot">&middot;</span>
        <div class="pf-history-stat">
          <span class="pf-history-stat-num">$30K</span>
          <span class="pf-history-stat-label">Raised</span>
        </div>
        <span class="pf-history-stat-dot">&middot;</span>
        <div class="pf-history-stat">
          <span class="pf-history-stat-num">2,100+</span>
          <span class="pf-history-stat-label">Attendees</span>
        </div>
      </div>
      <p>
        Pond Fest launched in 2024 and has grown into one of Delaware's
        favorite community outdoor festivals.
      </p>
      <a href="/pondfest/archive" class="pf-btn pf-btn--outline-light">
        View All Past Events
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .pf-hero {
    min-height: 85vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    display: flex;
    align-items: center;
  }
  .pf-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(11,9,23,0.7) 0%, rgba(11,9,23,0.85) 100%);
    display: flex;
