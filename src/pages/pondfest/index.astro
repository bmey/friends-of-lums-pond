<script>
  function setupFAQ() {
    const items = document.querySelectorAll(
      ".pf-faq-item",
    ) as NodeListOf<HTMLElement>;
    items.forEach((item) => {
      const btn = item.querySelector(".pf-faq-button") as HTMLButtonElement;
      const chevron = item.querySelector(
        ".pf-faq-chevron",
      ) as SVGElement | null;
      const content = item.querySelector(
        ".pf-faq-content",
      ) as HTMLElement | null;

      if (!btn || !content) return;

      btn.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");
        if (isOpen) {
          item.classList.remove("is-open");
          btn.setAttribute("aria-expanded", "false");
          content.style.maxHeight = "0px";
        } else {
          item.classList.add("is-open");
          btn.setAttribute("aria-expanded", "true");
          content.style.maxHeight = content.scrollHeight + "px";
        }
      });
    });
  }

  setupFAQ();
  document.addEventListener("astro:after-swap", setupFAQ);

  // ── Day-of mode detection ──────────────────────────────────────────
  function applyEventMode() {
    const panel = document.getElementById("pf-day-of-panel");
    if (!panel) return;

    const eventDateStr = panel.dataset.eventDate;
    if (!eventDateStr) return;

    const eventMs = new Date(eventDateStr).getTime();
    const now = Date.now();
    const sevenDaysMs = 7 * 24 * 60 * 60 * 1000;
    const oneDayMs = 24 * 60 * 60 * 1000;
    const diff = eventMs - now;

    const isDayOf = diff <= sevenDaysMs && diff > -oneDayMs;

    if (isDayOf) {
      panel.style.display = "";
    }
  }

  applyEventMode();
  document.addEventListener("astro:after-swap", applyEventMode);
</script>
