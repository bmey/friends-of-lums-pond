---
import Layout from "../../layouts/PondFestLayout.astro";
import PondFestCountdown from "../../components/pondfest/PondFestCountdown.astro";
import {
  CURRENT_YEAR,
  EVENT_DATE,
  EVENT_DATE_DISPLAY,
  EVENT_TIME,
  EVENT_LOCATION,
  EVENT_TAGLINE,
  FUNDRAISING_GOAL,
  HERO_IMAGE_URL,
  TICKETS_URL,
  VOLUNTEER_URL,
  SPONSOR_URL,
  VENDOR_URL,
  PERFORMER_URL,
  PONDFEST_EMAIL,
  LINEUP,
  SPONSORS,
  FUNDING_GOALS,
  FAQ,
  DAY_OF_ALERT,
  SHUTTLE_INFO,
  PARKING_NOTES,
  RAFFLE_LINK,
  AUCTION_LINK,
  FEEDBACK_LINK,
  DONATION_EMBED_URL,
  EVENT_MAP_IMAGE_URL,
  PARKING_MAP_IMAGE_URL,
  VENDOR_MAP_IMAGE_URL,
} from "../../data/pondfest/config";

const hasMaps = EVENT_MAP_IMAGE_URL || PARKING_MAP_IMAGE_URL || VENDOR_MAP_IMAGE_URL;

const sponsorsByTier = {
  platinum: SPONSORS.filter((s) => s.tier === "platinum"),
  gold: SPONSORS.filter((s) => s.tier === "gold"),
  silver: SPONSORS.filter((s) => s.tier === "silver"),
  bronze: SPONSORS.filter((s) => s.tier === "bronze"),
  family: SPONSORS.filter((s) => s.tier === "family"),
};

const hasSponsors = SPONSORS.length > 0;
const hasLineup = LINEUP.length > 0;

const ctaLinks = [
  {
    label: "Get Tickets",
    url: TICKETS_URL,
    style: "pf-btn--primary",
    icon: "fa-ticket",
  },
  {
    label: "Volunteer",
    url: VOLUNTEER_URL,
    style: "pf-btn--outline-light",
    icon: "fa-hand-holding-heart",
  },
  {
    label: "Sponsor",
    url: SPONSOR_URL,
    style: "pf-btn--outline-light",
    icon: "fa-star",
  },
  {
    label: "Vend",
    url: VENDOR_URL,
    style: "pf-btn--outline-light",
    icon: "fa-store",
  },
  {
    label: "Perform",
    url: PERFORMER_URL,
    style: "pf-btn--outline-light",
    icon: "fa-music",
  },
];

const features = [
  {
    icon: "fa-music",
    title: "Live Music",
    desc: "Multiple stages featuring local and regional artists throughout the day",
  },
  {
    icon: "fa-beer-mug-empty",
    title: "Beer Garden",
    desc: "Craft brews from Delaware's best local breweries (21+)",
  },
  {
    icon: "fa-utensils",
    title: "Food Trucks",
    desc: "A variety of local food trucks for every appetite",
  },
  {
    icon: "fa-child",
    title: "Kids Zone",
    desc: "Games, crafts, face painting, and activities for all ages",
  },
  {
    icon: "fa-store",
    title: "Craft Vendors",
    desc: "40+ local artisans, crafters, and community nonprofits",
  },
  {
    icon: "fa-ticket",
    title: "Raffles & Auction",
    desc: "Win exciting prizes donated by local businesses and supporters",
  },
];

const involvedPaths = [
  {
    icon: "fa-hand-holding-heart",
    title: "Volunteer",
    desc: "Help make Pond Fest happen. We need hands for setup, kids zone, info tables, and more.",
    url: VOLUNTEER_URL,
    cta: "Sign Up to Volunteer",
  },
  {
    icon: "fa-guitar",
    title: "Perform",
    desc: "Are you a local musician or performer? We want to hear from you.",
    url: PERFORMER_URL,
    cta: "Apply to Perform",
  },
  {
    icon: "fa-store",
    title: "Vend",
    desc: "Bring your business or craft to Pond Fest and connect with the community.",
    url: VENDOR_URL,
    cta: "Apply to Vend",
  },
  {
    icon: "fa-star",
    title: "Sponsor",
    desc: "Support the park and get visibility with hundreds of community members.",
    url: SPONSOR_URL,
    cta: "Become a Sponsor",
  },
];

const tierLabels: Record<string, string> = {
  platinum: "Platinum Sponsors",
  gold: "Gold Sponsors",
  silver: "Silver Sponsors",
  bronze: "Bronze Sponsors",
  family: "Family Sponsors",
};
---

<Layout
  title={`Pond Fest ${CURRENT_YEAR} | Friends of Lums Pond`}
  description={`Pond Fest ${CURRENT_YEAR} — ${EVENT_DATE_DISPLAY}. ${EVENT_TAGLINE}`}
>
  <!-- ══ ALERT BANNER (shown when DAY_OF_ALERT is set in config) ═════ -->
  {
    DAY_OF_ALERT && (
      <div class="pf-alert-banner" role="alert">
        <i class="fa-solid fa-circle-info" />
        {DAY_OF_ALERT}
      </div>
    )
  }

  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <section class="pf-hero" style={`background-image: url('${HERO_IMAGE_URL}')`}>
    <div class="pf-hero-overlay">
      <div class="pf-hero-content">
        <div class="pf-hero-eyebrow">Friends of Lums Pond presents</div>
        <h1 class="pf-hero-title">
          Pond Fest <span class="pf-hero-year">{CURRENT_YEAR}</span>
        </h1>
        <p class="pf-hero-meta">
          <i class="fa-solid fa-calendar-days"></i>
          {EVENT_DATE_DISPLAY}
          &nbsp;&middot;&nbsp;
          <i class="fa-solid fa-clock"></i>
          {EVENT_TIME}
          <br />
          <i class="fa-solid fa-location-dot"></i>
          {EVENT_LOCATION}
        </p>
        <p class="pf-hero-tagline">{EVENT_TAGLINE}</p>

        <PondFestCountdown startDate={EVENT_DATE} year={CURRENT_YEAR} />

        <div class="pf-hero-ctas">
          {
            ctaLinks.map((cta) =>
              cta.url ? (
                <a href={cta.url} class={`pf-btn ${cta.style}`} target="_blank" rel="noopener">
                  <i class={`fa-solid ${cta.icon}`} />
                  {cta.label}
                </a>
              ) : (
                <span class="pf-btn pf-btn--disabled" title="Link coming soon">
                  <i class={`fa-solid ${cta.icon}`} />
                  {cta.label}
                </span>
              )
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ══ DAY-OF PANEL (shown by JS when within 7 days of event) ══════ -->
  <div
    id="pf-day-of-panel"
    data-event-date={EVENT_DATE}
    style="display:none"
    class="pf-day-of-panel"
  >
    <!-- Quick navigation -->
    <section class="pf-section pf-section--purple">
      <div class="pf-section-inner">
        <h2>Day-of Quick Links</h2>
        <div class="pf-dayof-quicknav">
          {hasMaps && <a href="#pf-maps" class="pf-quicknav-btn"><i class="fa-solid fa-map"></i> Maps</a>}
          {RAFFLE_LINK && <a href={RAFFLE_LINK} target="_blank" rel="noopener" class="pf-quicknav-btn"><i class="fa-solid fa-ticket"></i> Raffles</a>}
          {AUCTION_LINK && <a href={AUCTION_LINK} target="_blank" rel="noopener" class="pf-quicknav-btn"><i class="fa-solid fa-gavel"></i> Auction</a>}
          {DONATION_EMBED_URL && <a href="#pf-donate" class="pf-quicknav-btn"><i class="fa-solid fa-circle-dollar-to-slot"></i> Donate</a>}
          {FEEDBACK_LINK && <a href={FEEDBACK_LINK} target="_blank" rel="noopener" class="pf-quicknav-btn"><i class="fa-solid fa-comment-dots"></i> Feedback</a>}
        </div>
      </div>
    </section>

    <!-- Maps -->
    {hasMaps && (
      <section class="pf-section pf-section--warm" id="pf-maps">
        <div class="pf-section-inner">
          <h2>Event Maps</h2>
          <div class="pf-maps-grid">
            {EVENT_MAP_IMAGE_URL && (
              <div class="pf-map-item">
                <h3>Event Map</h3>
                <a href={EVENT_MAP_IMAGE_URL} target="_blank" rel="noopener">
                  <img src={EVENT_MAP_IMAGE_URL} alt="Pond Fest event map" class="pf-map-img" loading="lazy" />
                  <span class="pf-map-tap-hint"><i class="fa-solid fa-magnifying-glass-plus"></i> Tap to enlarge</span>
                </a>
              </div>
            )}
            {PARKING_MAP_IMAGE_URL && (
              <div class="pf-map-item">
                <h3>Parking Map</h3>
                <a href={PARKING_MAP_IMAGE_URL} target="_blank" rel="noopener">
                  <img src={PARKING_MAP_IMAGE_URL} alt="Pond Fest parking map" class="pf-map-img" loading="lazy" />
                  <span class="pf-map-tap-hint"><i class="fa-solid fa-magnifying-glass-plus"></i> Tap to enlarge</span>
                </a>
              </div>
            )}
            {VENDOR_MAP_IMAGE_URL && (
              <div class="pf-map-item">
                <h3>Vendor Map</h3>
                <a href={VENDOR_MAP_IMAGE_URL} target="_blank" rel="noopener">
                  <img src={VENDOR_MAP_IMAGE_URL} alt="Pond Fest vendor map" class="pf-map-img" loading="lazy" />
                  <span class="pf-map-tap-hint"><i class="fa-solid fa-magnifying-glass-plus"></i> Tap to enlarge</span>
                </a>
              </div>
            )}
          </div>
          {PARKING_NOTES && (
            <div class="pf-parking-notes">
              <i class="fa-solid fa-circle-parking"></i>
              <p>{PARKING_NOTES}</p>
            </div>
          )}
          {SHUTTLE_INFO && (
            <div class="pf-shuttle-info">
              <i class="fa-solid fa-bus"></i>
              <p>{SHUTTLE_INFO}</p>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Raffle / Auction links -->
    {(RAFFLE_LINK || AUCTION_LINK) && (
      <section class="pf-section">
        <div class="pf-section-inner">
          <h2>Raffles &amp; Auction</h2>
          <div class="pf-dayof-link-cards">
            {RAFFLE_LINK && (
              <a href={RAFFLE_LINK} target="_blank" rel="noopener" class="pf-dayof-link-card">
                <i class="fa-solid fa-ticket pf-dayof-link-icon"></i>
                <div>
                  <strong>Raffle Info &amp; Results</strong>
                  <p>View raffle items and winner announcements</p>
                </div>
                <i class="fa-solid fa-arrow-right pf-dayof-link-arrow"></i>
              </a>
            )}
            {AUCTION_LINK && (
              <a href={AUCTION_LINK} target="_blank" rel="noopener" class="pf-dayof-link-card">
                <i class="fa-solid fa-gavel pf-dayof-link-icon"></i>
                <div>
                  <strong>Silent Auction</strong>
                  <p>View auction items and place or check bids</p>
                </div>
                <i class="fa-solid fa-arrow-right pf-dayof-link-arrow"></i>
              </a>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- Donation embed -->
    {DONATION_EMBED_URL && (
      <section class="pf-section pf-section--warm" id="pf-donate">
        <div class="pf-section-inner pf-donate-section">
          <h2>Donate Today</h2>
          <p>Every dollar raised goes directly to Lums Pond State Park programs and facilities.</p>
          <script src="https://donorbox.org/widget.js" paypalExpress="false" is:inline></script>
          <iframe
            src={DONATION_EMBED_URL}
            name="donorbox"
            allowpaymentrequest="allowpaymentrequest"
            seamless="seamless"
            frameborder="0"
            scrolling="no"
            height="900px"
            width="100%"
            style="max-width: 500px; min-width: 250px; max-height: none !important; display: block; margin: 0 auto;"
            allow="payment"
          />
        </div>
      </section>
    )}

    <!-- Feedback link -->
    {FEEDBACK_LINK && (
      <section class="pf-section pf-section--purple">
        <div class="pf-section-inner pf-feedback-section">
          <h2>Share Your Feedback</h2>
          <p>
            Thank you for spending the day with us at Pond Fest! Your feedback helps
            us make next year even better. It only takes two minutes.
          </p>
          <a href={FEEDBACK_LINK} target="_blank" rel="noopener" class="pf-btn pf-btn--outline-light">
            <i class="fa-solid fa-comment-dots"></i> Go to Survey
          </a>
        </div>
      </section>
    )}
  </div>
  <!-- ══ END DAY-OF PANEL ════════════════════════════════��═════════════ -->

  <!-- ══ FUNDRAISING GOALS ════════════════════════════════════════════ -->
  {
    FUNDING_GOALS.length > 0 && (
      <section class="pf-section pf-section--warm">
        <div class="pf-section-inner">
          <h2>Fundraising for {CURRENT_YEAR}</h2>
          <p class="pf-goals-goal">Goal: {FUNDRAISING_GOAL}</p>
          <div class="pf-goals-grid">
            {FUNDING_GOALS.map((goal) => (
              <div class="pf-goal-card pf-card">
                <div class="pf-goal-card-inner">
                  <div class="pf-goal-icon-wrap">
                    <i class="fa-solid fa-seedling" />
                  </div>
                  <h3>{goal.name}</h3>
                  <p>{goal.description}</p>
                  {goal.donorboxUrl && (
                    <a
                      href={goal.donorboxUrl}
                      class="pf-btn pf-btn--primary"
                      target="_blank"
                      rel="noopener"
                    >
                      Donate to this goal
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ══ WHAT TO EXPECT ═══════════════════════════════════════════════ -->
  <section class="pf-section">
    <div class="pf-section-inner">
      <h2>What to Expect</h2>
      <div class="pf-features-grid">
        {
          features.map((f) => (
            <div class="pf-feature-card pf-card">
              <div class="pf-feature-icon-wrap">
                <i class={`fa-solid ${f.icon}`} />
              </div>
              <h3 class="pf-feature-title">{f.title}</h3>
              <p class="pf-feature-desc">{f.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ══ MUSIC LINEUP ═════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--warm">
    <div class="pf-section-inner">
      <h2>Music Lineup</h2>
      {
        hasLineup ? (
          <div class="pf-lineup-grid">
            {LINEUP.map((performer) => (
              <div class="pf-performer-card">
                <i class="fa-solid fa-music pf-performer-icon" />
                <div class="pf-performer-info">
                  <strong>{performer.name}</strong>
                  {performer.stage && (
                    <span class="pf-performer-stage">{performer.stage}</span>
                  )}
                  {performer.time && (
                    <span class="pf-performer-time">{performer.time}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="pf-coming-soon">
            <i class="fa-solid fa-music pf-coming-soon-icon" />
            <h3 class="pf-coming-soon-headline">Lineup Coming Soon</h3>
            <p>
              Artist announcements drop as we get closer to October — follow us on{" "}
              <a
                href="https://www.facebook.com/FriendsofLumsPond"
                target="_blank"
                rel="noopener"
              >
                Facebook
              </a>{" "}
              so you don't miss it.
            </p>
          </div>
        )
      }
    </div>
  </section>

  <!-- ══ GET INVOLVED ═════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--purple">
    <div class="pf-section-inner">
      <h2>Get Involved</h2>
      <div class="pf-involved-grid">
        {
          involvedPaths.map((path) => (
            <div class="pf-involved-card">
              <i class={`fa-solid ${path.icon} pf-involved-icon`} />
              <h3>{path.title}</h3>
              <p>{path.desc}</p>
              {path.url ? (
                <a
                  href={path.url}
                  class="pf-btn pf-btn--outline-light"
                  target="_blank"
                  rel="noopener"
                >
                  {path.cta}
                </a>
              ) : (
                <span class="pf-btn pf-btn--disabled">{path.cta} — Coming Soon</span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ══ SPONSORS ═════════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--warm">
    <div class="pf-section-inner pf-sponsors-inner">
      <h2>Sponsors</h2>
      {
        hasSponsors ? (
          <div>
            {(
              ["platinum", "gold", "silver", "bronze", "family"] as const
            ).map(
              (tier) =>
                sponsorsByTier[tier].length > 0 && (
                  <div class="pf-sponsor-tier">
                    <h3 class="pf-sponsor-tier-label">{tierLabels[tier]}</h3>
                    <div class="pf-sponsor-list">
                      {sponsorsByTier[tier].map((s) =>
                        s.url ? (
                          <a
                            href={s.url}
                            target="_blank"
                            rel="noopener"
                            class="pf-sponsor-name"
                          >
                            {s.name}
                          </a>
                        ) : (
                          <span class="pf-sponsor-name">{s.name}</span>
                        )
                      )}
                    </div>
                  </div>
                )
            )}
          </div>
        ) : (
          <div class="pf-sponsor-empty">
            <p>
              Interested in sponsoring Pond Fest {CURRENT_YEAR}?
              <br />
              Reach out to us at{" "}
              <a href={`mailto:${PONDFEST_EMAIL}`}>{PONDFEST_EMAIL}</a>{" "}
              {SPONSOR_URL && (
                <>
                  {" "}
                  or{" "}
                  <a href={SPONSOR_URL} target="_blank" rel="noopener">
                    fill out our sponsor interest form
                  </a>
                  .
                </>
              )}
            </p>
          </div>
        )
      }
    </div>
  </section>

  <!-- ══ FAQ ══════════════════════════════════════════════════════════ -->
  <section class="pf-section">
    <div class="pf-section-inner">
      <h2>Frequently Asked Questions</h2>
      <div class="pf-faq">
        {
          FAQ.map((item, i) => (
            <div
              class="accordion group pf-faq-item"
              id={`faq-${i}`}
            >
              <button
                class="accordion__button pf-faq-button"
                type="button"
                aria-expanded="false"
                aria-controls={`faq-content-${i}`}
                id={`faq-btn-${i}`}
              >
                <span>{item.question}</span>
                <svg
                  class="accordion__chevron pf-faq-chevron"
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                >
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="m6 9l6 6l6-6"
                  />
                </svg>
              </button>
              <div
                id={`faq-content-${i}`}
                aria-labelledby={`faq-btn-${i}`}
                class="accordion__content pf-faq-content hidden"
              >
                <p>{item.answer}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ══ HISTORY TEASER ═══════════════════════════════════════════════ -->
  <section class="pf-section pf-section--dark">
    <div class="pf-section-inner pf-history-teaser">
      <h2>Our History</h2>
      <div class="pf-history-stats">
        <div class="pf-history-stat">
          <span class="pf-history-stat-num">2</span>
          <span class="pf-history-stat-label">Years</span>
        </div>
        <div class="pf-history-stat-divider">&middot;</div>
        <div class="pf-history-stat">
          <span class="pf-history-stat-num">$30K</span>
          <span class="pf-history-stat-label">Raised</span>
        </div>
        <div class="pf-history-stat-divider">&middot;</div>
        <div class="pf-history-stat">
          <span class="pf-history-stat-num">2,100+</span>
          <span class="pf-history-stat-label">Attendees</span>
        </div>
      </div>
      <p>
        Pond Fest launched in 2024 and has grown into one of Delaware's
        favorite community outdoor festivals.
      </p>
      <a href="/pondfest/archive" class="pf-btn pf-btn--outline-light">
        View All Past Events
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .pf-hero {
    min-height: 85vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    display: flex;
    align-items: center;
  }
  .pf-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 22, 41, 0.72) 0%,
      rgba(0, 22, 41, 0.82) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    box-sizing: border-box;
  }
  .pf-hero-content {
    text-align: center;
    color: #fff;
    max-width: 780px;
    width: 100%;
  }
  .pf-hero-eyebrow {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.8;
    margin-bottom: 0.5rem;
  }
  .pf-hero-title {
    font-family: var(--font-header);
    font-size: clamp(3rem, 12vw, 7rem);
    line-height: 0.95;
    color: #fff;
    margin: 0 0 0.3em 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
    letter-spacing: 0.02em;
  }
  .pf-hero-year {
    color: var(--pf-teal-light);
  }
  .pf-hero-meta {
    font-size: clamp(0.9rem, 2.5vw, 1.05rem);
    opacity: 0.9;
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }
  .pf-hero-meta i {
    opacity: 0.7;
    margin-right: 0.2em;
  }
  .pf-hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    opacity: 0.85;
    font-style: italic;
    margin-bottom: 1.5rem;
  }
  .pf-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .pf-hero-ctas .pf-btn {
    min-width: 130px;
  }

  /* ── Funding goals ── */
  .pf-goals-goal {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--pf-purple);
    margin-bottom: 1.5rem;
  }
  .pf-goals-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  .pf-goal-card {
    text-align: center;
  }
  .pf-goal-card-inner {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pf-goal-icon-wrap {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: var(--pf-teal);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    font-size: 1.4rem;
    color: #fff;
