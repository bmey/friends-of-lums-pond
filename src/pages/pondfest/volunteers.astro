---
import Layout from "../../layouts/PondFestLayout.astro";
import { CURRENT_YEAR, PONDFEST_EMAIL } from "../../data/pondfest/config";

// Password gate: SHA-256("iheartLUMS")
// The plaintext password is never stored here — only the hash.
// Verification happens entirely in the browser via Web Crypto API.
const PASSWORD_HASH =
  "590d53eafe1af77165bf5e4a5a761b88923abf4a25a6495314ca93b306e3e204";

// ─── Resource link data ────────────────────────────────────────────────────
// Update these URLs as documents are created or change locations.
// All links open in a new tab.

const googleDocs = [
  { label: "Pond Fest Policies & Guidelines", url: "" },
  { label: "Event Budget", url: "" },
  { label: "Sponsor Package", url: "" },
  { label: "Event Timeline / Master Run-of-Show", url: "" },
  { label: "Vendor Agreement", url: "" },
  { label: "Risk Assessment & Safety Plan", url: "" },
];

const forms = [
  { label: "Volunteer Sign-Up", url: "" },
  { label: "Performer Interest Form", url: "https://forms.gle/dMEmKxYs7ovnyG658" },
  { label: "Vendor Application", url: "" },
  { label: "Sponsor Interest Form", url: "" },
  { label: "Donation / Raffle Item Submission", url: "" },
  { label: "Post-Event Feedback Survey", url: "" },
];

const meetingNotes = [
  { label: "2026 Planning Meeting Notes (Google Drive folder)", url: "" },
  { label: "2025 Committee Notes Archive", url: "" },
];

const conceptMaps = [
  { label: "Event Layout Concept Map", url: "" },
  { label: "Volunteer Roles Org Chart", url: "" },
  { label: "Sponsorship Funnel Map", url: "" },
];

const roles = [
  {
    role: "Co-Chair",
    description: "Overall event leadership, final decision authority, external communications",
    signupUrl: "",
  },
  {
    role: "Vendor Coordinator",
    description: "Recruit and manage vendors, assign spots, day-of vendor check-in",
    signupUrl: "",
  },
  {
    role: "Sponsor Coordinator",
    description: "Outreach to sponsors, manage packages, ensure sponsor recognition at event",
    signupUrl: "",
  },
  {
    role: "Volunteer Coordinator",
    description: "Recruit and schedule volunteers, manage sign-up system, day-of volunteer assignments",
    signupUrl: "",
  },
  {
    role: "Music / Entertainment Coordinator",
    description: "Book performers, manage stage schedule, coordinate with sound",
    signupUrl: "",
  },
  {
    role: "Kids Zone Lead",
    description: "Plan and run the kids zone: activities, crafts, staffing",
    signupUrl: "",
  },
  {
    role: "Raffle & Auction Coordinator",
    description: "Solicit raffle donations, manage items, run day-of raffle",
    signupUrl: "",
  },
  {
    role: "Logistics & Setup Lead",
    description: "Tent/table rental, day-of setup and teardown crew",
    signupUrl: "",
  },
  {
    role: "Marketing & Social Media",
    description: "Event promotion across social media, flyers, press outreach",
    signupUrl: "",
  },
  {
    role: "Website / Tech",
    description: "Maintain the event website, QR codes, day-of digital resources",
    signupUrl: "",
  },
];

const keyContacts = [
  {
    name: "Bryan Mey",
    role: "President / Co-Chair",
    contact: "pondfest@friendsoflumspond.org",
    notes: "Technology, sponsorship, general leadership",
  },
  {
    name: "Jessie Mey",
    role: "Co-Chair",
    contact: "",
    notes: "Experience design, community outreach, volunteers",
  },
  {
    name: "Jenny Grady",
    role: "Vendor Coordinator",
    contact: "",
    notes: "All vendor and crafter questions",
  },
  {
    name: "Bob Conley Sr",
    role: "Logistics",
    contact: "",
    notes: "Setup, teardown, physical logistics",
  },
