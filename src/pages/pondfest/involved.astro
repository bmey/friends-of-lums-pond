---
import Layout from "../../layouts/PondFestLayout.astro";
import {
  CURRENT_YEAR,
  VOLUNTEER_URL,
  PERFORMER_URL,
  VENDOR_URL,
  SPONSOR_URL,
  PONDFEST_EMAIL,
} from "../../data/pondfest/config";

const paths = [
  {
    icon: "fa-hand-holding-heart",
    title: "Volunteer",
    heading: "Help Make Pond Fest Happen",
    description:
      "Pond Fest runs on the energy and dedication of volunteers. Whether you can help with setup and teardown, run the kids zone, staff the information tables, assist with vendors, or help day-of in any number of ways — we need you. No experience necessary, just enthusiasm for the park and community.",
    details: [
      "Flexible shifts — half day or full day",
      "Volunteer perks: free admission and a thank-you gift",
      "Great opportunity for students needing service hours",
      "Join a fun, welcoming group of park supporters",
    ],
    url: VOLUNTEER_URL,
    cta: "Sign Up to Volunteer",
    imageUrl: "", // e.g. "/pondfest/photos/volunteers.jpg"
    gradientFrom: "#1a1040",
    gradientTo: "#2ac4b3",
    section: "pf-section--dark",
    reverse: false,
  },
  {
    icon: "fa-guitar",
    title: "Perform",
    heading: "Share Your Music with the Community",
    description:
      "Pond Fest features live music all day across multiple outdoor stages. We welcome local and regional artists of all genres. Whether you are a solo act, duo, or full band, we would love to hear from you. Fill out our performer interest form and tell us about yourself.",
    details: [
      "Multiple outdoor stages (Wingspan, Monarch, Nest Box)",
      "Open Mic slots available throughout the day",
      "Headlining and supporting act positions",
      "Exposure to 1,000+ community members",
    ],
    url: PERFORMER_URL,
    cta: "Apply to Perform",
    imageUrl: "", // e.g. "/pondfest/photos/performers.jpg"
    gradientFrom: "#271e52",
    gradientTo: "#6b5db5",
    section: "pf-section--dark-alt",
    reverse: true,
  },
  {
    icon: "fa-store",
    title: "Vend",
    heading: "Bring Your Business to Pond Fest",
    description:
      "Join 40+ local artisans, crafters, and community nonprofits at Pond Fest. It is a fantastic opportunity to connect with hundreds of community members who appreciate supporting local. We welcome food vendors, craft makers, artisans, service businesses, and nonprofits.",
    details: [
      "Outdoor vendor spaces in a scenic park setting",
      "Audience of 1,000+ engaged community members",
      "Table and tent space available",
      "Past vendors include crafters, local businesses, and nonprofits",
    ],
    url: VENDOR_URL,
    cta: "Apply to Vend",
    imageUrl: "", // e.g. "/pondfest/photos/vendors.jpg"
    gradientFrom: "#0b2a28",
    gradientTo: "#2ac4b3",
    section: "pf-section--dark",
    reverse: false,
  },
  {
    icon: "fa-star",
    title: "Sponsor",
    heading: "Support the Park and Get Visibility",
    description:
      "Pond Fest sponsorships directly fund Lums Pond State Park programs and facilities. In return, your business or organization gets prominent recognition at the event and across our marketing materials. We offer tiered sponsorship packages from Family-level to Platinum.",
    details: [
      "Recognition at the event and on event signage",
      "Listing on this website under your sponsor tier",
      "Mention in social media and email communications",
      "Good-will with 1,000+ community members who attend",
    ],
    url: SPONSOR_URL,
    cta: "Become a Sponsor",
    imageUrl: "", // e.g. "/pondfest/photos/sponsors.jpg"
    gradientFrom: "#271e52",
    gradientTo: "#3d2f7a",
    section: "pf-section--dark-alt",
    reverse: true,
  },
];
---

<Layout
  title={`Get Involved — Pond Fest ${CURRENT_YEAR} | Friends of Lums Pond`}
  description={`Volunteer, perform, vend, or sponsor Pond Fest ${CURRENT_YEAR} at Lums Pond State Park.`}
>
  <!-- ══ HEADER ═════════════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--dark involved-header">
    <div class="pf-section-inner pf-section-inner--narrow" style="text-align:center">
      <span class="pf-eyebrow">Four Ways to Participate</span>
      <h1 class="involved-title">Get Involved</h1>
      <p>
        Pond Fest is a community effort. There are four ways to be part of it
        — as a volunteer, performer, vendor, or sponsor. Choose your path
        below.
      </p>
      <a href="/pondfest" class="pf-btn pf-btn--outline-light">
        <i class="fa-solid fa-arrow-left"></i> Back to Pond Fest
      </a>
    </div>
  </section>

  <!-- ══ PATHWAY SECTIONS ══════════════════════════════════════════════ -->
  {
    paths.map((path) => (
      <section class={`pf-section pf-section--flush ${path.section}`}>
        <div class={`pf-split${path.reverse ? " pf-split--reverse" : ""}`}>
          {/* Media side */}
          <div class="pf-split-media">
            {path.imageUrl ? (
              <img src={path.imageUrl} alt={path.title} />
            ) : (
              <div
                class="pathway-placeholder"
                style={`background: linear-gradient(135deg, ${path.gradientFrom} 0%, ${path.gradientTo} 100%)`}
              >
                <i class={`fa-solid ${path.icon}`} />
              </div>
            )}
          </div>

          {/* Text side */}
          <div class="pf-split-text">
            <span class="pf-eyebrow">{path.title}</span>
            <h2>{path.heading}</h2>
            <p class="pathway-desc">{path.description}</p>
            <ul class="pathway-details">
              {path.details.map((d) => (
                <li>
                  <i class="fa-solid fa-check" /> {d}
                </li>
              ))}
            </ul>
            <div class="pathway-cta">
              {path.url ? (
                <a
                  href={path.url}
                  class="pf-btn pf-btn--primary"
                  target="_blank"
                  rel="noopener"
                >
                  {path.cta}
                </a>
              ) : (
                <div class="coming-soon-wrap">
                  <span class="pf-btn pf-btn--disabled">
                    {path.cta} — Opening Soon
                  </span>
                  <p class="cta-fallback">
                    In the meantime, email{" "}
                    <a href={`mailto:${PONDFEST_EMAIL}`}>{PONDFEST_EMAIL}</a>
                  </p>
                </div>
              )}
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <!-- ══ CONTACT ═══════════════════════════════════════════════════════ -->
  <section class="pf-section pf-section--purple">
    <div class="pf-section-inner pf-section-inner--narrow" style="text-align:center">
      <h2>Questions?</h2>
      <p>
        Reach out to the Pond Fest committee at
        <a href={`mailto:${PONDFEST_EMAIL}`} class="contact-link"
          >{PONDFEST_EMAIL}</a
        > — we are happy to help with anything not covered by the forms above.
      </p>
    </div>
  </section>
</Layout>

<style>
  /* ── Page header ── */
  .involved-title {
    font-family: var(--font-header);
    font-size: clamp(2.2rem, 6vw, 4rem);
    color: var(--pf-teal-light);
    margin-bottom: 0.75rem;
    letter-spacing: 0.03em;
    line-height: 1.05;
  }
  .involved-header p {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1.5rem;
  }

  /* ── Pathway placeholder (icon on gradient) ── */
  .pathway-placeholder {
    width: 100%;
    height: 100%;
    min-height: clamp(300px, 40vw, 600px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(4rem, 10vw, 8rem);
    color: rgba(255, 255, 255, 0.18);
  }

  /* ── Split text content ── */
  .pathway-desc {
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .pathway-details {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .pathway-details li {
    font-size: 0.95rem;
    display: flex;
    align-items: baseline;
    gap: 0.6em;
  }
  .pathway-details li i {
    color: var(--pf-teal);
    font-size: 0.8rem;
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  /* Dark section detail text */
  .pf-section--dark .pathway-details li,
  .pf-section--dark-alt .pathway-details li {
    color: rgba(255, 255, 255, 0.8);
  }

  .pathway-cta {
    margin-top: auto;
  }
  .coming-soon-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cta-fallback {
    font-size: 0.85rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.5);
  }
  .cta-fallback a {
    color: var(--pf-teal-light);
    text-decoration: none;
  }
  .cta-fallback a:hover {
    text-decoration: underline;
  }

  /* ── Contact section ── */
  .contact-link {
    color: var(--pf-teal-light);
    text-decoration: none;
  }
  .contact-link:hover {
    text-decoration: underline;
  }
</style>
