---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_DESCRIPTION } from "../consts";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description || SITE_DESCRIPTION} />
    <style>
      :root {
        --pf-purple: #3d2f7a;
        --pf-purple-light: #6b5db5;
        --pf-purple-dark: #271e52;
        --pf-teal: #2ac4b3;
        --pf-teal-light: #4dd9cb;
        --pf-warm-bg: #fffbf5;
        --pf-warm-section: #fff8ee;
      }
      body {
        background-color: var(--pf-warm-bg);
      }
      main {
        width: 100%;
        padding: 0;
      }

      /* ── Shared section styles used across Pond Fest pages ── */
      .pf-section {
        padding: 5rem 1.5rem;
        width: 100%;
        box-sizing: border-box;
      }
      .pf-section--warm {
        background-color: var(--pf-warm-section);
      }
      .pf-section--purple {
        background-color: var(--pf-purple);
        color: #fff;
      }
      .pf-section--purple h2,
      .pf-section--purple h3,
      .pf-section--purple p {
        color: #fff;
      }
      .pf-section--dark {
        background-color: var(--pf-purple-dark);
        color: #fff;
      }
      .pf-section--dark h2,
      .pf-section--dark h3,
      .pf-section--dark p {
        color: #fff;
      }
      .pf-section-inner {
        max-width: 900px;
        margin: 0 auto;
      }
      .pf-section h2 {
        font-family: var(--font-header);
        font-size: clamp(2rem, 5vw, 3.2rem);
        text-align: center;
        margin-bottom: 2rem;
        letter-spacing: 0.03em;
      }
      .pf-section--purple h2 {
        color: var(--pf-teal-light);
      }
      .pf-section--dark h2 {
        color: var(--pf-teal);
      }

      /* ── Eyebrow label utility ── */
      .pf-eyebrow {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-weight: 700;
        opacity: 0.6;
        text-align: center;
        display: block;
        margin-bottom: 0.4rem;
      }

      /* ── Card base ── */
      .pf-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07), 0 1px 4px rgba(0, 0, 0, 0.04);
        overflow: hidden;
      }

      /* ── Button styles ── */
      .pf-btn {
        display: inline-block;
        padding: 0.65rem 1.4rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 2px solid transparent;
        white-space: nowrap;
        letter-spacing: 0.04em;
      }
      .pf-btn--primary {
        background-color: var(--pf-teal);
        color: #fff;
        border-color: var(--pf-teal);
      }
      .pf-btn--primary:hover {
        background-color: #1fa899;
        border-color: #1fa899;
        color: #fff;
      }
      .pf-btn--purple {
        background-color: var(--pf-purple);
        color: #fff;
        border-color: var(--pf-purple);
      }
      .pf-btn--purple:hover {
        background-color: var(--pf-purple-light);
        border-color: var(--pf-purple-light);
        color: #fff;
      }
      .pf-btn--outline {
        background-color: transparent;
        color: var(--pf-purple);
        border-color: var(--pf-purple);
      }
      .pf-btn--outline:hover {
        background-color: var(--pf-purple);
        color: #fff;
      }
      .pf-btn--outline-light {
        background-color: transparent;
        color: #fff;
        border-color: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(4px);
      }
      .pf-btn--outline-light:hover {
        background-color: rgba(255, 255, 255, 0.15);
        border-color: #fff;
      }
      .pf-btn--disabled {
        background-color: var(--color-gray-200);
        color: var(--color-gray-500);
        border-color: var(--color-gray-200);
        cursor: default;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
